# Firecrawl Self-Hosted Configuration
# Copy to .env and customize

# Server
PORT=3002

# PostgreSQL (defaults used if not set)
POSTGRES_USER=firecrawl
POSTGRES_PASSWORD=firecrawl
POSTGRES_DB=firecrawl

# RabbitMQ (defaults used if not set)
RABBITMQ_USER=firecrawl
RABBITMQ_PASSWORD=firecrawl

# Queue settings
NUM_WORKERS_PER_QUEUE=8
CRAWL_CONCURRENT_REQUESTS=10
MAX_CONCURRENT_JOBS=5
BROWSER_POOL_SIZE=5

# Admin UI key (CHANGE if exposing to public network)
BULL_AUTH_KEY=CHANGEME

# Logging
LOGGING_LEVEL=info

# ---- Optional: AI Extraction ----
# Uncomment to enable /v1/extract endpoint
# OPENAI_API_KEY=sk-xxx

# Or use Ollama:
# OLLAMA_BASE_URL=http://host.docker.internal:11434/api
# MODEL_NAME=qwen2.5:7b

# ---- Optional: Search ----
# Uncomment + install SearXNG to enable /v1/search
# SEARXNG_ENDPOINT=http://searxng:8080

# ---- Optional: Proxy ----
# PROXY_SERVER=http://proxy:8080
